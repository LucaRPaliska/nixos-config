[{
    "height": 20,
    "spacing": 0,

    "modules-left": [
        "group/utilities",
        "group/windows",
	"group/network",
        "mpris"
    ],
    "modules-center": [
        "group/workspaces"
    ],
    "modules-right": [
        "group/cpuram",
    	"group/clock",
        "group/system"
    ],

    "custom/openbracket": {
        "format": "[",
        "tooltip": false
    },
    "custom/closebracket": {
        "format": "]",
        "tooltip": false
    },    
    "custom/split": {
      "format": "|",
      "tooltip": false
    },

    "group/utilities":{
        "orientation": "horizontal",
        "modules":[
            "custom/openbracket",
            "custom/power",
            "custom/split",
            "idle_inhibitor",
            "custom/bluetooth",
            "custom/closebracket"
        ]
    },
    "custom/power": {
    	"format": "ŌÅ╗ ",
  	"tooltip": false,
	"on-click": "~/.config/waybar/scripts/power_menu/power_menu.sh",
	"tooltip": "Power Menu"
    },   
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "’ü«",
            "deactivated": "’ü░"
        }
    },
    "custom/bluetooth": {
    	"format": "’Ŗö",
